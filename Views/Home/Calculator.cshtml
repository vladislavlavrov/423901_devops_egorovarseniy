@model Calculator.Models.CalculatorModel

@{
    ViewData["Title"] = "Калькулятор";
}

<h2>Простой калькулятор (Егоров А.А. НМТ-423901)</h2>


<form asp-action="Calculator" asp-controller="Home" method="post">
    <div class="form-group">
        <label asp-for="Number1">Первое число:</label>
        <input asp-for="Number1" class="form-control" type="number" step="any" required />
        <span asp-validation-for="Number1" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Operation">Операция:</label>
        <select asp-for="Operation" class="form-control" required>
            <option value="">Выберите операцию</option>
            <option value="+">+ (Сложение)</option>
            <option value="-">- (Вычитание)</option>
            <option value="*">* (Умножение)</option>
            <option value="/">/ (Деление)</option>
        </select>
        <span asp-validation-for="Operation" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Number2">Второе число:</label>
        <input asp-for="Number2" class="form-control" type="number" step="any" required />
        <span asp-validation-for="Number2" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Вычислить</button>
</form>

@if (Model != null)
{
    <div class="mt-3">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">
                @Model.ErrorMessage
            </div>
        }
        else if (Model.Result != 0)
        {
            <div class="alert alert-success">
                <strong>Результат:</strong> @Model.Number1@Model.Operation@Model.Number2 = @Model.Result
            </div>
        }
    </div>
}